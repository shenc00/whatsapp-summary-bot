# Copy this file to ".env" and fill in your values.

# Required — get one at https://console.anthropic.com/ (Settings → API Keys)
ANTHROPIC_API_KEY=sk-ant-...

# Optional — which Claude model to use.
#   claude-opus-4-8   (default, most capable)
#   claude-haiku-4-5  (faster + cheaper, good for high-volume auto-reply)
CLAUDE_MODEL=claude-opus-4-8

# Optional — default number of messages !summary pulls in when no count is given.
SUMMARY_MESSAGE_COUNT=50

# Optional — path to an installed Chrome/Edge/Chromium, so Puppeteer doesn't
# need to download its own. Leave unset to use the bundled browser.
#   Windows Chrome: C:\Program Files\Google\Chrome\Application\chrome.exe
#   Windows Edge:   C:\Program Files (x86)\Microsoft\Edge\Application\msedge.exe
#   Termux/Android: /data/data/com.termux/files/usr/bin/chromium
# CHROME_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe

# Optional — link by PAIRING CODE instead of QR. Set this to your WhatsApp
# number in full international format, digits only (country code + number,
# no "+" or spaces), e.g. 6591234567. Needed when the bot runs on the same
# phone you're linking, since you can't scan an on-screen QR with that phone.
# PAIRING_PHONE_NUMBER=6591234567
