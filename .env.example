# Copy this file to ".env" and fill in your values.

# Required — get one at https://console.anthropic.com/ (Settings → API Keys)
ANTHROPIC_API_KEY=sk-ant-...

# Optional — which Claude model to use.
#   claude-opus-4-8   (default, most capable)
#   claude-haiku-4-5  (faster + cheaper, good for high-volume auto-reply)
CLAUDE_MODEL=claude-opus-4-8

# Optional — default number of messages !summary pulls in when no count is given.
SUMMARY_MESSAGE_COUNT=50
